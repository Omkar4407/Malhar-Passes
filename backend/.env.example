# --- Server Configuration ---
PORT=5050
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# --- Supabase Configuration ---
# Found in Project Settings -> API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth & Security ---
# Generate these using: openssl rand -hex 32
JWT_SECRET=your-random-jwt-secret
OTP_HMAC_SECRET=your-random-otp-hmac-secret

# Static passwords for Admin/Scanner login
ADMIN_PASSWORD=your-strong-admin-password
SCANNER_PASSWORD=your-strong-scanner-password

# --- SMS Service (Fast2SMS) ---
# Set to 'true' to log OTPs to console instead of sending real SMS
DEV_MODE=true
FAST2SMS_API_KEY=your-fast2sms-api-key

# --- Payment Gateway (Razorpay) ---
# Note: Ensure frontend is also using Razorpay to match these keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
