# Copy to tests/.env and fill in (or export in shell)

# API target
MALHAR_API_URL=http://localhost:5000
# express (Node) or supabase (edge function paths)
MALHAR_API_STYLE=express

# From backend/.env — lets tests mint JWTs for concurrency
JWT_SECRET=your-jwt-secret-here

# Optional: use a real logged-in user token instead of minting
TEST_USER_TOKEN=
TEST_ADMIN_TOKEN=

# Slot/event UUIDs from Supabase for booking stress tests
TEST_SLOT_ID=
TEST_EVENT_ID=

# Load tuning
STRESS_WORKERS=50
STRESS_READ_REQUESTS=100
BOOKING_STRESS_WORKERS=30
READ_P95_MS=2000

# OTP tests (optional, hits rate limits)
RUN_OTP_TESTS=0
TEST_PHONE=9876543210
